generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  name      String?
  roles     Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Articles {
  id        String   @id @default(uuid())
  title     String
  detail    String
  content   String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Products {
  id          String @id @default(uuid())
  make        String
  model       String
  year        String
  trim        String
  size        String
  mfg         String
  description String
  detail      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model productDetail {
  id                     String   @id @default(uuid())
  brand                  String?
  model                  String?
  name                   String?
  loadRange              String?
  utqg                   String?
  sidewall               String?
  section_width          String?
  aspect_ratio           String?
  rim_size               String?
  inch_width             String?
  diameter               String?
  overall_diameter       String?
  load_rating            String?
  speed_rating           String?
  load_capacity_single   String?
  max_inflation_pressure String?
  measuring_rim_width    String?
  approved_rim_width_max String?
  approved_rim_width_min String?
  revolutions_per_mile   String?
  weight                 String?
  origin                 String?
  thumbnail_image        String
  images                 String[]
  features               String?
  benefits               String?
  description            String?
  tags                   String?
  rim_protector          String?
  size                   String
  tread_depth            String?
  overall_width          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Stock {
  id          String   @id @default(uuid())
  mfg         String
  item        String
  size        String
  price       Float
  description String
  quantity    Int
  fet         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
