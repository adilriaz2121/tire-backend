generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum FinSystem {
  fcs
  fcs11
  futures
}

enum Role {
  user
  admin
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String?
  name      String?
  roles     Role     @default(admin)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
