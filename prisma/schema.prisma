generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum FinSystem {
  fcs
  fcs11
  futures
}

enum Role {
  user
  admin
}

enum DiscountType {
  percentage
  fixed
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String?
  name      String?
  roles     Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Articles {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  detail    String
  content   String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model coupons {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  code         String
  discountType DiscountType @default(percentage)
  discount     Float
  validFrom    DateTime?
  validTo      DateTime?
  maxUse       Int?
  usedCount    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}
