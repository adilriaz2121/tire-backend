generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum FinSystem {
  fcs
  fcs11
  futures
}

enum Role {
  user
  admin
}

enum DiscountType {
  percentage
  fixed
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String?
  name      String?
  roles     Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Articles {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  detail    String
  content   String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model company {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model products {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  make        String
  model       String
  year        String
  trim        String
  size        String
  mfg         String
  item        String
  detail      String
  description String
  quantity    Int
  images      String[]
  price       Float
  reviews     Reviews[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Contact {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  isRead    String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  pending
  shipped
  delivered
  cancelled
}

model order {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String
  phone       String
  totalAmount Float
  productIds  String[]
  address     String
  city        String
  state       String?
  zip         String?
  country     String
  total       Float
  status      OrderStatus @default(pending)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Reviews {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  country    String?
  review     String
  rating     Int
  isApproved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  products   products? @relation(fields: [productsId], references: [id])
  productsId String?   @db.ObjectId
}

model coupons {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  code         String
  discountType DiscountType @default(percentage)
  discount     Float
  validFrom    DateTime?
  validTo      DateTime?
  maxUse       Int?
  usedCount    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}
