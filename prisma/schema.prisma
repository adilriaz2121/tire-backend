generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  name      String?
  roles     Role     @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Articles {
  id        String   @id @default(uuid())
  title     String
  detail    String
  content   String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Products {
  id          String @id @default(uuid())
  make        String
  model       String
  year        String
  trim        String
  size        String
  mfg         String
  description String
  detail      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contacts {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reviews {
  id                 String   @id @default(uuid())
  Dry                Int
  Wet                Int
  Winter             Int
  size               String
  brand              String
  Comfort            Int
  Noise              Int
  Treadwear          Int
  summary            String?
  additionalComments String?
  name               String
  email              String
  purchaseDate       DateTime
  vehicle            String
  milesDriven        String
  drivingStyle       String
  wouldBuyAgain      String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model productDetail {
  id                     String   @id @default(uuid())
  brand                  String?
  model                  String?
  name                   String?
  loadRange              String?
  utqg                   String?
  sidewall               String?
  section_width          String?
  aspect_ratio           String?
  rim_size               String?
  inch_width             String?
  diameter               String?
  overall_diameter       String?
  load_rating            String?
  speed_rating           String?
  load_capacity_single   String?
  max_inflation_pressure String?
  measuring_rim_width    String?
  approved_rim_width_max String?
  approved_rim_width_min String?
  revolutions_per_mile   String?
  weight                 String?
  origin                 String?
  thumbnail_image        String
  images                 String[]
  features               String?
  benefits               String?
  description            String?
  tags                   String?
  rim_protector          String?
  size                   String
  tread_depth            String?
  overall_width          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Stock {
  id          String   @id @default(uuid())
  mfg         String
  item        String
  size        String
  price       Float
  description String
  quantity    Int
  fet         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ShippingLocation {
  MobileInstaller
  LocalInstaller
  ShipToMe
  FedExPickup
}

enum OrderStatus {
  confirmed
  shipped
  delivered
  cancelled
}

model Orders {
  id          String  @id @default(uuid())
  userName    String
  email       String
  phone       String
  totalAmount Float
  address     String
  city        String
  discount       Float?
  couponCode     String?
  trackingNumber String?

  status           OrderStatus      @default(confirmed)
  state            String
  zip              String
  shippingLocation ShippingLocation @default(MobileInstaller)
  country          String
  installerId      String?
  installerName    String?
  appointmentDate  DateTime?
  orderItems       OrderItems[]
}

enum DiscountType {
  percentage
  fixed
}

model Coupons {
  id           String       @id @default(uuid())
  code         String       @unique
  discountType DiscountType
  discount     Float
  validFrom    DateTime?
  validTo      DateTime?
  maxUse       Int?
  usedCount    Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model OrderItems {
  id                 String   @id @default(uuid())
  orderId            String
  order              Orders   @relation(fields: [orderId], references: [id])
  productName        String
  productPrice       Float
  productQuantity    Int
  productTotal       Float
  productImage       String
  productBrand       String
  productModel       String
  productYear        String
  productTrim        String
  productSize        String
  productMfg         String
  productDescription String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
